import androidx.lifecycle.viewmodel.compose.viewModel
import androidx.navigation.NavType
import androidx.navigation.compose.NavHost
import androidx.navigation.compose.composable
import androidx.navigation.compose.rememberNavController
import androidx.navigation.navArgument
import com.retrogb.data.bios.BiosManager
import com.retrogb.data.saf.SafPermissionManager
import com.retrogb.ui.home.HomeScreen
import com.retrogb.ui.home.HomeViewModel
import com.retrogb.ui.home.LoadGameScreen
import com.retrogb.ui.ingame.InGameScreen
import com.retrogb.ui.main.MainScreen
import com.retrogb.ui.onboarding.OnboardingScreen
import com.retrogb.ui.settings.SettingsScreen
import kotlinx.coroutines.launch

@Composable
fun RetroGbNavigation(
    hasSafPermission: Boolean,
    onRequestPermission: (Uri) -> Unit
) {
    val navController = rememberNavController()
    val context = LocalContext.current
    val homeViewModel: HomeViewModel = viewModel()
    val snackbarHostState = remember { SnackbarHostState() }
    val scope = rememberCoroutineScope()

    // Start destination: if we have permission, go to Main Menu, else Onboarding
    val startDest = if (hasSafPermission) "main_menu" else "onboarding"

    LaunchedEffect(hasSafPermission) {
        if (hasSafPermission) {
            val safManager = SafPermissionManager(context)
            safManager.getPersistedUri()?.let { uri ->
                homeViewModel.scanRoms(uri)
            }
        }
    }

    Scaffold(
        snackbarHost = { SnackbarHost(snackbarHostState) }
    ) { paddingValues ->
        NavHost(
            navController = navController,
            startDestination = startDest,
            modifier = Modifier.padding(paddingValues)
        ) {
            composable("onboarding") {
                OnboardingScreen { uri ->
                    onRequestPermission(uri)
                    homeViewModel.scanRoms(uri)
                    navController.navigate("main_menu") {
                        popUpTo("onboarding") { inclusive = true }
                    }
                }
            }

            composable("main_menu") {
                MainScreen(
                    onLoadRom = { navController.navigate("home") },
                    onContinueGame = { navController.navigate("load_game") },
                    onSettings = { navController.navigate("settings") }
                )
            }

            composable("home") {
                val games by homeViewModel.games.collectAsState()
                HomeScreen(
                    games = games,
                    onGameClick = { game ->
                        val act = context as? android.app.Activity
                        if (act != null) {
                            com.retrogb.monetization.AdMobHelper.getInstance().showLoadingInterstitial(act) {
                                navController.navigate("ingame/${Uri.encode(game.uriString)}/${game.crc32}")
                            }
                        } else {
                            navController.navigate("ingame/${Uri.encode(game.uriString)}/${game.crc32}")
                        }
                    },
                    onChangeFolder = {
                        navController.navigate("onboarding")
                    },
                    onBack = { navController.popBackStack() }
                )
            }

            composable("load_game") {
                val games by homeViewModel.games.collectAsState()
                LoadGameScreen(
                    games = games,
                    onLoadSlot = { game, slotId ->
                        val act = context as? android.app.Activity
                        if (act != null) {
                            com.retrogb.monetization.AdMobHelper.getInstance().showLoadingInterstitial(act) {
                                navController.navigate("ingame/${Uri.encode(game.uriString)}/${game.crc32}?slot=$slotId")
                            }
                        } else {
                            navController.navigate("ingame/${Uri.encode(game.uriString)}/${game.crc32}?slot=$slotId")
                        }
                    },
                    onBack = { navController.popBackStack() }
                )
            }

            composable("settings") {
                SettingsScreen(
                    onBack = { navController.popBackStack() }
                )
            }

            composable(
                route = "ingame/{uri}/{gameId}?slot={slot}",
                arguments = listOf(
                    navArgument("uri") { type = NavType.StringType },
                    navArgument("gameId") { type = NavType.StringType },
                    navArgument("slot") { 
                        type = NavType.IntType
                        defaultValue = -1 
                    }
                )
            ) { backStackEntry ->
                val uri = backStackEntry.arguments?.getString("uri") ?: ""
                val gameId = backStackEntry.arguments?.getString("gameId") ?: ""
                val slotId = backStackEntry.arguments?.getInt("slot")?.takeIf { it != -1 }
                
                InGameScreen(
                    gameUri = uri,
                    gameId = gameId,
                    initialSlotId = slotId,
                    onBack = { navController.popBackStack() }
                )
            }
        }
    }
}


