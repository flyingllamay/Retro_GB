            IconButton(onClick = { showMenu = true }, modifier = Modifier.background(Color.Black.copy(alpha = 0.5f), MaterialTheme.shapes.small)) {
                Icon(Icons.Default.Menu, contentDescription = "Menu", tint = Color.White)
            }
        }
        
        SnackbarHost(hostState = snackbarHostState, modifier = Modifier.align(Alignment.BottomCenter).zIndex(5f))
        
        // Cheats Bottom Sheet
        if (showCheatMenu) {
            var showAddDialog by remember { mutableStateOf(false) }
            var cheatToEdit by remember { mutableStateOf<Cheat?>(null) }
            
            ModalBottomSheet(
                onDismissRequest = { showCheatMenu = false },
                containerColor = Color(0xFF222222)
