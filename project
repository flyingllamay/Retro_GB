package com.retrogb.data.saf

import android.content.Context
import android.net.Uri
import androidx.documentfile.provider.DocumentFile
import androidx.work.CoroutineWorker
import androidx.work.WorkerParameters
import com.retrogb.data.db.GameDatabase
import com.retrogb.data.db.GameEntity
import java.util.zip.CRC32

class RomScanWorker(
    appContext: Context,
    workerParams: WorkerParameters
) : CoroutineWorker(appContext, workerParams) {

    override suspend fun doWork(): Result {
        val uriString = inputData.getString("folder_uri") ?: return Result.failure()
        val uri = Uri.parse(uriString)
        
        val folder = DocumentFile.fromTreeUri(applicationContext, uri)
            ?: return Result.failure()
            
        val games = mutableListOf<GameEntity>()
        scanFolder(folder, games)
        
        val db = GameDatabase.getDatabase(applicationContext)
        db.gameDao().deleteAll()
        db.gameDao().insertAll(games)
        
        return Result.success()
    }

    private fun scanFolder(folder: DocumentFile, games: MutableList<GameEntity>) {
        folder.listFiles().forEach { file ->
            if (file.isDirectory) {
                scanFolder(file, games)
            } else {
                val name = file.name ?: return@forEach
                
                // Automatically discover and copy a valid 16KB GBA BIOS from the ROM folder
                if (name.equals("gba_bios.bin", ignoreCase = true) || name.equals("bios.bin", ignoreCase = true)) {
                    val size = file.length()
                    if (size == 16384L) {
                        try {
                            val biosDir = java.io.File(applicationContext.filesDir, "bios").apply { mkdirs() }
                            val biosFile = java.io.File(biosDir, "gba_bios.bin")
                            applicationContext.contentResolver.openInputStream(file.uri)?.use { input ->
                                biosFile.outputStream().use { output -> input.copyTo(output) }
                            }
                            android.util.Log.i("RomScanWorker", "Successfully imported valid 16KB GBA BIOS from ROM folder!")
                        } catch (e: java.lang.Exception) {
                            android.util.Log.e("RomScanWorker", "Failed to copy GBA BIOS", e)
                        }
                    } else {
                        android.util.Log.w("RomScanWorker", "Found GBA BIOS but size is invalid ($size bytes, expected 16384). Ignoring.")
                    }
                    return@forEach
                }

                val system = when {
                    name.endsWith(".gb", ignoreCase = true) -> "GB"
                    name.endsWith(".gbc", ignoreCase = true) -> "GBC"
                    name.endsWith(".gba", ignoreCase = true) -> "GBA"
                    else -> null
                }
                
                if (system != null) {
                    val uri = file.uri
                    val crc = calculateCrc32(uri)
                    games.add(GameEntity(
                        uriString = uri.toString(),
                        name = name.substringBeforeLast("."),
                        mimeType = file.type ?: "application/octet-stream",
                        crc32 = crc,
                        system = system
                    ))
                }
            }
        }
    }

    private fun calculateCrc32(uri: Uri): Long {
        return try {
            val crc = CRC32()
            applicationContext.contentResolver.openInputStream(uri)?.use { input ->
                val buffer = ByteArray(8192)
                var read: Int
                while (input.read(buffer).also { read = it } != -1) {
                    crc.update(buffer, 0, read)
                }
            }
            crc.value
        } catch (e: Exception) {
            0L
        }
    }
}


