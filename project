package com.retrogb.data.saf

import android.content.Context
import android.content.Intent
import android.net.Uri

class SafPermissionManager(private val context: Context) {
    
    fun persistPermission(uri: Uri) {
        context.contentResolver.takePersistableUriPermission(
            uri,
            Intent.FLAG_GRANT_READ_URI_PERMISSION or Intent.FLAG_GRANT_WRITE_URI_PERMISSION
        )
        val prefs = context.getSharedPreferences("saf_prefs", Context.MODE_PRIVATE)
        prefs.edit().putString("rom_folder_uri", uri.toString()).apply()
    }
    
    fun getPersistedUri(): Uri? {
        val prefs = context.getSharedPreferences("saf_prefs", Context.MODE_PRIVATE)
        val uriString = prefs.getString("rom_folder_uri", null) ?: return null
        return Uri.parse(uriString)
    }

    fun isPermissionValid(uri: Uri): Boolean {
        return context.contentResolver.persistedUriPermissions
            .any { it.uri == uri && it.isReadPermission }
    }
}


