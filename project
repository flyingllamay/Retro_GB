package com.retrogb.data.bios

import android.content.Context
import android.net.Uri
import java.io.File
import java.io.FileOutputStream

class BiosManager(private val context: Context) {
    
    fun setupDefaultBios() {
        val biosDir = File(context.filesDir, "bios")
        if (!biosDir.exists()) {
            biosDir.mkdirs()
        }
        
        val destFile = File(biosDir, "gba_bios.bin")
        if (!destFile.exists()) {
            try {
                // Copia il BIOS open source (Normmatt) da assets a filesDir
                context.assets.open("bios/gba_bios_normmatt.bin").use { input ->
                    FileOutputStream(destFile).use { output ->
                        input.copyTo(output)
                    }
                }
            } catch (e: Exception) {
                e.printStackTrace()
            }
        }
    }

    fun importOfficialBios(uri: Uri): Boolean {
        return try {
            val biosDir = File(context.filesDir, "bios")
            if (!biosDir.exists()) biosDir.mkdirs()
            
            val destFile = File(biosDir, "gba_bios.bin")
            context.contentResolver.openInputStream(uri)?.use { input ->
                FileOutputStream(destFile).use { output ->
                    input.copyTo(output)
                }
            }
            true
        } catch (e: Exception) {
            e.printStackTrace()
            false
        }
    }
}


