class AdMobHelper private constructor(private val context: Context) {
    
    private var loadingInterstitialAd: InterstitialAd? = null
    private var savingInterstitialAd: InterstitialAd? = null

    init {
        MobileAds.initialize(context) {}
        loadLoadingInterstitial()
        loadSavingInterstitial()
    }

    private fun loadLoadingInterstitial() {
        val adRequest = AdRequest.Builder().build()
        // ID reale per interstitial caricamento gioco
        InterstitialAd.load(context, "ca-app-pub-1801837203896511/2251063319", adRequest,
            object : InterstitialAdLoadCallback() {
                override fun onAdFailedToLoad(adError: LoadAdError) {
                    loadingInterstitialAd = null
                }
