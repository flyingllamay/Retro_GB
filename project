private const val TAG = "RetroGB"

object RetroCoreManager {
    // Holds a Deferred that completes when the previous core is fully destroyed.
    // New games wait on this before creating a GLRetroView.
    @Volatile
    var previousCoreDestroyed: kotlinx.coroutines.CompletableDeferred<Unit> = kotlinx.coroutines.CompletableDeferred<Unit>().also { it.complete(Unit) }
}

private suspend fun prepareRom(context: Context, gameUri: String, gameId: String): Pair<String, String>? {
    return withContext(Dispatchers.IO) {
        try {
            val cursor = context.contentResolver.query(
                Uri.parse(gameUri),
                arrayOf(android.provider.OpenableColumns.DISPLAY_NAME),
                null, null, null
            )
            val filename = cursor?.use { c ->
                if (c.moveToFirst()) c.getString(0) else null
            } ?: "rom.bin"

            val decodedUri = Uri.decode(gameUri)
            val isGba = filename.endsWith(".gba", ignoreCase = true) ||
                        decodedUri.contains(".gba", ignoreCase = true) ||
                        gameUri.contains(".gba", ignoreCase = true) ||
                        gameUri.contains("%2Egba", ignoreCase = true)
            
            val ext = if (isGba) "gba" else "gb"
            
            // Sanitize gameId for file name
            val cleanId = gameId.replace("[^a-zA-Z0-9]".toRegex(), "_")
            val tempFile = File(context.cacheDir, "${cleanId}.${ext}")
            
            // Clean up other cached ROMs to save space
            try {
                context.cacheDir.listFiles()?.forEach { file ->
                    if (file.name != tempFile.name && (file.name.endsWith(".gba") || file.name.endsWith(".gb") || file.name.contains("temp_rom"))) {
                        file.delete()
                    }
                }
            } catch (e: Exception) {
                Log.e(TAG, "Error cleaning cache", e)
            }

            context.contentResolver.openInputStream(Uri.parse(gameUri))?.use { input ->
                tempFile.outputStream().use { output -> input.copyTo(output) }
            }
            
            val coreName = if (isGba) "libmgba_libretro_android.so" else "gearboy_libretro_android.so"
            val corePath = File(context.applicationInfo.nativeLibraryDir, coreName).absolutePath
            
            Pair(tempFile.absolutePath, corePath)
        } catch (e: Exception) {
            Log.e(TAG, "Error preparing ROM", e)
            null
        }
    }
}

data class SaveSlot(val id: Int, val dateMs: Long, val imagePath: String, val statePath: String)

@OptIn(ExperimentalMaterial3Api::class)
@Composable
fun InGameScreen(
    gameUri: String,
    gameId: String,
    initialSlotId: Int? = null,
    onBack: () -> Unit
) {
    val context = LocalContext.current
    val lifecycleOwner = LocalLifecycleOwner.current
    val scope = rememberCoroutineScope()
    val settingsManager = remember { SettingsManager(context) }
    val cheatManager = remember(gameId) { CheatManager(context, gameId) }
    
    var romPaths by remember { mutableStateOf<Pair<String, String>?>(null) }
    var retroView by remember { mutableStateOf<GLRetroView?>(null) }
    var showMenu by remember { mutableStateOf(false) }
    var showCheatMenu by remember { mutableStateOf(false) }
    var showExitDialog by remember { mutableStateOf(false) }
    var isTurboActive by remember { mutableStateOf(false) }
    val snackbarHostState = remember { SnackbarHostState() }
    
    var cheatsList by remember { mutableStateOf(cheatManager.loadCheats()) }
    
    fun applyCheats(view: GLRetroView) {
        cheatsList.forEachIndexed { index, cheat ->
            view.setCheat(index, cheat.isEnabled, cheat.code, false)
        }
    }

    val configuration = LocalConfiguration.current
    val isLandscape = configuration.orientation == android.content.res.Configuration.ORIENTATION_LANDSCAPE

    // Functions defined at the top to avoid unresolved references
    fun getSavesDir(): File {
        val dir = File(context.filesDir, "saves/$gameId")
        dir.mkdirs()
        return dir
    }

    fun getSlots(): List<SaveSlot> {
        val dir = getSavesDir()
        return (1..5).map { id ->
            val stateFile = File(dir, "slot_$id.state")
            val imgFile = File(dir, "slot_$id.png")
            if (stateFile.exists()) {
                SaveSlot(id, stateFile.lastModified(), imgFile.absolutePath, stateFile.absolutePath)
            } else {
                SaveSlot(id, 0L, "", "")
            }
        }
    }

    fun loadFromSlot(slotId: Int, view: GLRetroView) {
        try {
            val dir = getSavesDir()
            val stateFile = File(dir, "slot_$slotId.state")
            if (stateFile.exists()) {
                val state = stateFile.readBytes()
                view.unserializeState(state, true)
                scope.launch { snackbarHostState.showSnackbar("State loaded from Slot $slotId") }
                showMenu = false
            }
        } catch (e: Exception) {
            Log.e(TAG, "Load failed", e)
        }
    }

    // Hide status bar and navigation bar for immersive experience
    val activity = context as? Activity
    LaunchedEffect(Unit) {
        activity?.window?.let { window ->
            val controller = WindowCompat.getInsetsController(window, window.decorView)
            controller.hide(WindowInsetsCompat.Type.systemBars())
            controller.systemBarsBehavior = WindowInsetsControllerCompat.BEHAVIOR_SHOW_TRANSIENT_BARS_BY_SWIPE
        }
    }

    LaunchedEffect(gameUri, gameId) {
        romPaths = prepareRom(context, gameUri, gameId)
    }

    LaunchedEffect(isTurboActive) {
        retroView?.frameSpeed = if (isTurboActive) 8 else 1
    }

    LaunchedEffect(retroView) {
        retroView?.let { view ->
            while (!view.isShown) delay(100)
            delay(1500)
            
            // Apply original screen filter if enabled
            if (settingsManager.originalScreenEnabled) {
                view.shader = ShaderConfig.LCD
            }
            
            if (initialSlotId != null && romPaths != null) {
                loadFromSlot(initialSlotId, view)
            } else {
                val startKey = KeyEvent.KEYCODE_BUTTON_START
                view.sendKeyEvent(KeyEvent.ACTION_DOWN, startKey, 0)
                delay(100)
                view.sendKeyEvent(KeyEvent.ACTION_UP, startKey, 0)
            }
            
            // Re-apply cheats
            applyCheats(view)
        }
    }

    // Auto-save: call this BEFORE onBack() while the GL view is still alive and valid
    fun performAutoSave() {
        retroView?.let { view ->
            try {
                val state = view.serializeState()
                val dir = getSavesDir()
                File(dir, "slot_0.state").writeBytes(state)
                Log.d(TAG, "Auto-saved to slot 0")
            } catch (e: Exception) {
                Log.e(TAG, "Auto-save failed", e)
            }
        }
    }

    // JNI teardown only — keyed on lifecycleOwner so it fires exactly once when the screen leaves
    DisposableEffect(lifecycleOwner) {
        onDispose {
            val view = retroView ?: return@onDispose
            // Signal to the next InGameScreen that it must wait for us
            val destroyedSignal = kotlinx.coroutines.CompletableDeferred<Unit>()
            RetroCoreManager.previousCoreDestroyed = destroyedSignal
            // Detach lifecycle observer immediately
            lifecycleOwner.lifecycle.removeObserver(view)
            // Destroy the native core fully off the main thread
            @OptIn(DelicateCoroutinesApi::class)
            GlobalScope.launch(Dispatchers.IO) {
                try {
                    view.onDestroy()
                    Log.d(TAG, "GLRetroView JNI destroyed in background")
                } catch (e: Exception) {
                    Log.e(TAG, "Error destroying GLRetroView JNI in background", e)
                } finally {
                    destroyedSignal.complete(Unit)
                }
            }
        }
    }
    
    BackHandler {
        performAutoSave()
        onBack()
    }

    // Monitor saves directory for both in-game saves (.srm) and slot saves (.state)
    DisposableEffect(gameId) {
        val savesDir = File(context.filesDir, "saves")
        val gameSavesDir = File(savesDir, gameId)
        savesDir.mkdirs()
        gameSavesDir.mkdirs()

        var lastTriggerTime = 0L
        val mainHandler = Handler(Looper.getMainLooper())

        val triggerAd = {
            val now = System.currentTimeMillis()
            if (now - lastTriggerTime > 8000) { // 8 seconds debounce
                lastTriggerTime = now
                mainHandler.post {
                    val act = context as? Activity
                    if (act != null) {
                        try {
                            com.retrogb.monetization.AdMobHelper.getInstance().showSavingInterstitial(act) {}
                        } catch (e: Exception) {
                            Log.e("SaveObserver", "Failed to show interstitial ad", e)
                        }
                    }
                }
            }
        }

        // Observer for in-game saves in the main saves directory
        val mainObserver = if (android.os.Build.VERSION.SDK_INT >= android.os.Build.VERSION_CODES.Q) {
            object : FileObserver(savesDir, CLOSE_WRITE or CREATE or MODIFY) {
                override fun onEvent(event: Int, path: String?) {
                    if (path != null && (path.endsWith(".srm") || path.endsWith(".sav") || path.endsWith(".flash"))) {
                        triggerAd()
                    }
                }
            }
        } else {
            @Suppress("DEPRECATION")
            object : FileObserver(savesDir.absolutePath, CLOSE_WRITE or CREATE or MODIFY) {
                override fun onEvent(event: Int, path: String?) {
                    if (path != null && (path.endsWith(".srm") || path.endsWith(".sav") || path.endsWith(".flash"))) {
                        triggerAd()
                    }
                }
            }
        }

        // Observer for slot-saves in the game-specific directory
        val slotObserver = if (android.os.Build.VERSION.SDK_INT >= android.os.Build.VERSION_CODES.Q) {
            object : FileObserver(gameSavesDir, CLOSE_WRITE or CREATE or MODIFY) {
                override fun onEvent(event: Int, path: String?) {
                    if (path != null && path.endsWith(".state") && !path.contains("slot_0")) { // Ignore auto-save slot_0
                        triggerAd()
                    }
                }
            }
        } else {
            @Suppress("DEPRECATION")
            object : FileObserver(gameSavesDir.absolutePath, CLOSE_WRITE or CREATE or MODIFY) {
                override fun onEvent(event: Int, path: String?) {
                    if (path != null && path.endsWith(".state") && !path.contains("slot_0")) { // Ignore auto-save slot_0
                        triggerAd()
                    }
                }
            }
        }

        mainObserver.startWatching()
        slotObserver.startWatching()

        onDispose {
            mainObserver.stopWatching()
            slotObserver.stopWatching()
        }
    }

    if (showExitDialog) {
        AlertDialog(
            onDismissRequest = { showExitDialog = false },
            title = { Text("Exit Game") },
            text = { Text("Your progress has been auto-saved.") },
            confirmButton = {
                TextButton(onClick = {
                    showExitDialog = false
                    performAutoSave()
                    onBack()
                }) { Text("Yes, exit") }
            },
            dismissButton = {
                TextButton(onClick = { showExitDialog = false }) { Text("No") }
            }
        )
    }

    var slots by remember { mutableStateOf<List<SaveSlot>>(emptyList()) }

    LaunchedEffect(showMenu) {
        if (showMenu && romPaths != null) {
            slots = getSlots()
        }
    }

    fun saveToSlot(slotId: Int, view: GLRetroView) {
        scope.launch(Dispatchers.IO) {
            try {
                val state = view.serializeState()
                val dir = getSavesDir()
                val stateFile = File(dir, "slot_$slotId.state")
                stateFile.writeBytes(state)
                
                // Screenshot via PixelCopy (must be on UI thread or with handler)
                withContext(Dispatchers.Main) {
                    val act = context as? Activity
                    if (act != null && act.window != null) {
                        val bitmap = Bitmap.createBitmap(view.width, view.height, Bitmap.Config.ARGB_8888)
                        val location = IntArray(2)
                        view.getLocationInWindow(location)
                        val surfaceView = view as? android.view.SurfaceView
                        if (surfaceView != null) {
                            PixelCopy.request(
                                surfaceView,
                                null, // Full surface
                                bitmap,
                                { copyResult ->
                                    if (copyResult == PixelCopy.SUCCESS) {
                                        scope.launch(Dispatchers.IO) {
                                            val imgFile = File(dir, "slot_$slotId.png")
                                            FileOutputStream(imgFile).use { out ->
                                                bitmap.compress(Bitmap.CompressFormat.PNG, 90, out)
                                            }
                                            slots = getSlots() // Refresh
                                            snackbarHostState.showSnackbar("State saved in Slot $slotId")
                                        }
                                    } else {
                                        Log.e(TAG, "PixelCopy failed with result: $copyResult")
                                    }
                                },
                                Handler(Looper.getMainLooper())
                            )
                        } else {
                            // Fallback to window request if not a SurfaceView
                            PixelCopy.request(
                                act.window,
                                android.graphics.Rect(location[0], location[1], location[0] + view.width, location[1] + view.height),
                                bitmap,
                                { copyResult ->
                                    if (copyResult == PixelCopy.SUCCESS) {
                                        scope.launch(Dispatchers.IO) {
                                            val imgFile = File(dir, "slot_$slotId.png")
                                            FileOutputStream(imgFile).use { out ->
                                                bitmap.compress(Bitmap.CompressFormat.PNG, 90, out)
                                            }
                                            slots = getSlots() // Refresh
                                            snackbarHostState.showSnackbar("State saved in Slot $slotId")
                                        }
                                    }
                                },
                                Handler(Looper.getMainLooper())
                            )
                        }
                    }
                }
            } catch (e: Exception) {
                Log.e(TAG, "Save failed", e)
            }
        }
    }

    Box(modifier = Modifier.fillMaxSize().background(Color.Black)) {
        if (romPaths != null) {
            val (romPath, corePath) = romPaths!!

            // UNIFIED LAYOUT TO PREVENT CRASH
            val portraitPaddingBottom = configuration.screenHeightDp.dp * 0.48f
