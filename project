package com.retrogb.data.cheats

import android.content.Context
import org.json.JSONArray
import org.json.JSONObject
import java.io.File

data class Cheat(
    val id: String,
    val name: String,
    val code: String,
    var isEnabled: Boolean
)

class CheatManager(private val context: Context, private val gameId: String) {

    private val cheatsFile: File
        get() {
            val dir = File(context.filesDir, "saves/$gameId")
            dir.mkdirs()
            return File(dir, "cheats.json")
        }

    fun loadCheats(): List<Cheat> {
        if (!cheatsFile.exists()) return emptyList()
        val cheats = mutableListOf<Cheat>()
        try {
            val jsonArray = JSONArray(cheatsFile.readText())
            for (i in 0 until jsonArray.length()) {
                val obj = jsonArray.getJSONObject(i)
                cheats.add(
                    Cheat(
                        id = obj.getString("id"),
                        name = obj.getString("name"),
                        code = obj.getString("code"),
                        isEnabled = obj.getBoolean("isEnabled")
                    )
                )
            }
        } catch (e: Exception) {
            e.printStackTrace()
        }
        return cheats
    }

    fun saveCheats(cheats: List<Cheat>) {
        try {
            val jsonArray = JSONArray()
            for (cheat in cheats) {
                val obj = JSONObject()
                obj.put("id", cheat.id)
                obj.put("name", cheat.name)
                obj.put("code", cheat.code)
                obj.put("isEnabled", cheat.isEnabled)
                jsonArray.put(obj)
            }
            cheatsFile.writeText(jsonArray.toString())
        } catch (e: Exception) {
            e.printStackTrace()
        }
    }
}


