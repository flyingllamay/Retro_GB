package com.retrogb.ui.ingame

import android.graphics.Paint
import android.graphics.Typeface
import android.view.HapticFeedbackConstants
import androidx.compose.foundation.Canvas
import androidx.compose.foundation.layout.*
import androidx.compose.runtime.*
import androidx.compose.ui.ExperimentalComposeUiApi
import androidx.compose.ui.Modifier
import androidx.compose.ui.geometry.CornerRadius
import androidx.compose.ui.geometry.Offset
import androidx.compose.ui.geometry.Size
import androidx.compose.ui.graphics.*
import androidx.compose.ui.graphics.drawscope.DrawScope
import androidx.compose.ui.graphics.drawscope.drawIntoCanvas
import androidx.compose.ui.input.pointer.pointerInteropFilter
import androidx.compose.ui.platform.LocalContext
import androidx.compose.ui.platform.LocalDensity

@OptIn(ExperimentalComposeUiApi::class)
@Composable
fun TouchOverlay(
    modifier: Modifier = Modifier,
    isLandscape: Boolean,
    retroView: com.swordfish.libretrodroid.GLRetroView,
    onButtonEvent: (Int, Boolean) -> Unit
) {
    val context = LocalContext.current
    val density = LocalDensity.current.density
    val pressedButtons = remember { mutableStateMapOf<Int, Boolean>() }
    val lastSentStates = remember { mutableStateMapOf<Int, Boolean>() }

    BoxWithConstraints(modifier = modifier.fillMaxSize()) {
        val wPx = constraints.maxWidth.toFloat()
        val hPx = constraints.maxHeight.toFloat()
        val wDp = wPx / density
        val hDp = hPx / density

        Box(
            modifier = Modifier
                .fillMaxSize()
                .pointerInteropFilter { event ->
                    handleTouch(event, isLandscape, wDp, hDp, density) { id, pressed ->
                        if (pressed != lastSentStates[id]) {
                            if (pressed) {
                                android.view.View(context).performHapticFeedback(HapticFeedbackConstants.VIRTUAL_KEY)
                            }
                            lastSentStates[id] = pressed
                            pressedButtons[id] = pressed
                            onButtonEvent(id, pressed)
                        }
                    }
                    true
                }
        ) {
            Canvas(modifier = Modifier.fillMaxSize()) {
                drawRetroConsoleControls(this, isLandscape, wDp, hDp, density, pressedButtons)
            }
        }
    }
}

private fun drawRetroConsoleControls(
    scope: DrawScope,
    isLandscape: Boolean,
    wDp: Float,
    hDp: Float,
    density: Float,
    pressed: Map<Int, Boolean>
) {
    with(scope) {
        // Classic Console Colors
        val dpadColor = Color(0xFF2A2A2A)
        val dpadPressed = Color(0xFF111111)
        val abColor = Color(0xFF333333) // Grey like D-Pad
        val abPressed = Color(0xFF111111)
        val pillColor = Color(0xFF5A5C68)
        val pillPressed = Color(0xFF3A3C48)
        
        // Turbo custom colors (Glowing neon green styling)
        val turboColor = Color(0xFF4CAF50).copy(alpha = 0.6f)
        val turboPressed = Color(0xFF4CAF50)
        
        // Setup Paint for text
        val textPaint = Paint().apply {
            color = android.graphics.Color.LTGRAY
            textAlign = Paint.Align.CENTER
            typeface = Typeface.DEFAULT_BOLD
            textSize = 16f * density
        }
        val buttonTextPaint = Paint().apply {
            color = android.graphics.Color.WHITE
            textAlign = Paint.Align.CENTER
            typeface = Typeface.DEFAULT_BOLD
            textSize = 20f * density
        }
        val pillTextPaint = Paint().apply {
            color = android.graphics.Color.WHITE
            textAlign = Paint.Align.CENTER
            typeface = Typeface.DEFAULT_BOLD
            textSize = 13f * density // Slightly smaller for TURBO
        }

        fun drawTextCentred(text: String, x: Float, y: Float, paint: Paint) {
            drawIntoCanvas { canvas ->
                val textOffset = (paint.descent() + paint.ascent()) / 2
                canvas.nativeCanvas.drawText(text, x * density, (y * density) - textOffset, paint)
            }
        }

        fun drawDPad(cx: Float, cy: Float) {
            val center = Offset(cx * density, cy * density)
            val totalSize = 130f * density
            val armWidth = 44f * density
            val halfSize = totalSize / 2f
            val halfArm = armWidth / 2f
            
            // Background shadow
            drawRoundRect(Color.Black.copy(alpha = 0.5f), Offset(center.x - halfArm + 2f*density, center.y - halfSize + 4f*density), Size(armWidth, totalSize), CornerRadius(4f * density))
            drawRoundRect(Color.Black.copy(alpha = 0.5f), Offset(center.x - halfSize + 2f*density, center.y - halfArm + 4f*density), Size(totalSize, armWidth), CornerRadius(4f * density))

            // Main crosses
            drawRoundRect(dpadColor, Offset(center.x - halfArm, center.y - halfSize), Size(armWidth, totalSize), CornerRadius(4f * density))
            drawRoundRect(dpadColor, Offset(center.x - halfSize, center.y - halfArm), Size(totalSize, armWidth), CornerRadius(4f * density))
            
            // Pressed states
            if (pressed[4] == true) drawRoundRect(dpadPressed, Offset(center.x - halfArm, center.y - halfSize), Size(armWidth, halfSize), CornerRadius(4f * density)) // Up
            if (pressed[5] == true) drawRoundRect(dpadPressed, Offset(center.x - halfArm, center.y), Size(armWidth, halfSize), CornerRadius(4f * density)) // Down
            if (pressed[6] == true) drawRoundRect(dpadPressed, Offset(center.x - halfSize, center.y - halfArm), Size(halfSize, armWidth), CornerRadius(4f * density)) // Left
            if (pressed[7] == true) drawRoundRect(dpadPressed, Offset(center.x, center.y - halfArm), Size(halfSize, armWidth), CornerRadius(4f * density)) // Right

            // Center circle decoration
            drawCircle(Color(0xFF1E1E1E), 12f * density, center)
        }

        fun drawRoundBtn(id: Int, cx: Float, cy: Float, label: String) {
            val isPressed = pressed[id] == true
            val center = Offset(cx * density, cy * density)
            val rad = 38f * density
            
            // Drop shadow
            drawCircle(Color.Black.copy(alpha = 0.5f), rad, Offset(center.x + 2f*density, center.y + 4f*density))
            
            // Button body
            drawCircle(if (isPressed) abPressed else abColor, rad, center)
            
            // Inner ring for 3D effect
            drawCircle(Color.Black.copy(alpha = 0.2f), rad - 2f*density, center, style = androidx.compose.ui.graphics.drawscope.Stroke(2f*density))
            
            // Label INSIDE
            drawTextCentred(label, cx, cy, buttonTextPaint)
        }

        fun drawPillBtn(id: Int, cx: Float, cy: Float, w: Float, h: Float, label: String) {
            val isPressed = pressed[id] == true
            val width = w * density
            val height = h * density
            val topLeft = Offset((cx - w/2) * density, (cy - h/2) * density)
            val size = Size(width, height)
            val corner = CornerRadius(height / 2f)

            // Shadow
            drawRoundRect(Color.Black.copy(alpha = 0.5f), Offset(topLeft.x + 2f*density, topLeft.y + 4f*density), size, corner)
            
            // Body
            drawRoundRect(if (isPressed) pillPressed else pillColor, topLeft, size, corner)
            
            // Label INSIDE the button
            drawTextCentred(label, cx, cy, pillTextPaint)
        }

        fun drawTurboBtn(cx: Float, cy: Float, w: Float, h: Float, label: String) {
            val isPressed = pressed[12] == true
            val width = w * density
            val height = h * density
            val topLeft = Offset((cx - w/2) * density, (cy - h/2) * density)
            val size = Size(width, height)
            val corner = CornerRadius(height / 2f)

            // Shadow
            drawRoundRect(Color.Black.copy(alpha = 0.5f), Offset(topLeft.x + 2f*density, topLeft.y + 4f*density), size, corner)
            
            // Body
            drawRoundRect(if (isPressed) turboPressed else turboColor, topLeft, size, corner)
            
            // Label INSIDE
            drawTextCentred(label, cx, cy, pillTextPaint)
        }

        if (isLandscape) {
            // Left margin constraints: 0 to 140dp
            drawDPad(cx = 70f, cy = hDp / 2f + 3f) // Aligned bottom with B
            drawPillBtn(id = 10, cx = 70f, cy = 80f, w = 90f, h = 35f, label = "L")
            
            // Turbo: Positioned below D-pad (between D-pad and Select)
            drawTurboBtn(cx = 70f, cy = hDp - 75f, w = 90f, h = 30f, label = "TURBO")
            
            // Select: Positioned at the very bottom left
            drawPillBtn(id = 2, cx = 70f, cy = hDp - 35f, w = 80f, h = 25f, label = "SELECT")

            // Right margin constraints: wDp - 140dp to wDp
            drawRoundBtn(id = 8, cx = wDp - 45f, cy = hDp / 2f - 20f, label = "A")
            drawRoundBtn(id = 0, cx = wDp - 105f, cy = hDp / 2f + 30f, label = "B")
            drawPillBtn(id = 11, cx = wDp - 70f, cy = 80f, w = 90f, h = 35f, label = "R")
            // Start
            drawPillBtn(id = 3, cx = wDp - 70f, cy = hDp - 40f, w = 80f, h = 25f, label = "START")

        } else {
            // -- PORTRAIT LAYOUT -- (Touch overlay takes bottom 45% of screen, wDp x hDp)
            drawDPad(cx = 90f, cy = hDp / 2f - 3f) // Aligned top with A
            
            drawRoundBtn(id = 8, cx = wDp - 50f, cy = hDp / 2f - 30f, label = "A")
            drawRoundBtn(id = 0, cx = wDp - 120f, cy = hDp / 2f + 20f, label = "B")
            
            // L & R at the top of the control area with TURBO shifted higher
            drawTurboBtn(cx = 60f, cy = 10f, w = 80f, h = 25f, label = "TURBO")
            drawPillBtn(id = 10, cx = 60f, cy = 75f, w = 80f, h = 30f, label = "L")
            drawPillBtn(id = 11, cx = wDp - 60f, cy = 75f, w = 80f, h = 30f, label = "R")
            
            // Select & Start at bottom center
            drawPillBtn(id = 2, cx = wDp / 2f - 60f, cy = hDp - 40f, w = 80f, h = 25f, label = "SELECT")
            drawPillBtn(id = 3, cx = wDp / 2f + 60f, cy = hDp - 40f, w = 80f, h = 25f, label = "START")
        }
    }
}

private fun handleTouch(
    event: android.view.MotionEvent,
    isLandscape: Boolean,
    wDp: Float,
    hDp: Float,
    density: Float,
    onEvent: (Int, Boolean) -> Unit
) {
    val action = event.actionMasked
    val pointerCount = event.pointerCount

    val activeButtons = mutableSetOf<Int>()
    for (i in 0 until pointerCount) {
        val x = event.getX(i) / density
        val y = event.getY(i) / density

        val id = if (isLandscape) {
            getLandscapeButtonAt(x, y, wDp, hDp)
        } else {
            getPortraitButtonAt(x, y, wDp, hDp)
        }
        if (id != -1) activeButtons.add(id)
    }

    if (action == android.view.MotionEvent.ACTION_UP || action == android.view.MotionEvent.ACTION_CANCEL) {
        activeButtons.clear()
    }

    val allIds = listOf(0, 2, 3, 4, 5, 6, 7, 8, 10, 11, 12)
    for (id in allIds) {
        val isPressed = activeButtons.contains(id)
        onEvent(id, isPressed)
    }
}

private fun getLandscapeButtonAt(x: Float, y: Float, wDp: Float, hDp: Float): Int {
    // D-PAD: cx = 70f, cy = hDp / 2f + 3f
    val dpadCx = 70f
    val dpadCy = hDp / 2f + 3f
    if (dist(x, y, dpadCx, dpadCy) < 80f) {
        val dx = x - dpadCx
        val dy = y - dpadCy
        return if (Math.abs(dx) > Math.abs(dy)) {
            if (dx > 0) 7 else 6
        } else {
            if (dy > 0) 5 else 4
        }
    }
    
    // A: cx = wDp - 45f, cy = hDp / 2f - 20f
    if (dist(x, y, wDp - 45f, hDp / 2f - 20f) < 55f) return 8
    // B: cx = wDp - 105f, cy = hDp / 2f + 30f
    if (dist(x, y, wDp - 105f, hDp / 2f + 30f) < 55f) return 0
    
    // L: cx = 70f, cy = 80f
    if (x < 120f && y in 50f..110f) return 10
    // R: cx = wDp - 70f, cy = 80f
    if (x > wDp - 120f && y in 50f..110f) return 11
    
    // Turbo: cx = 70f, cy = hDp - 75f
    if (x < 120f && y in (hDp - 95f)..(hDp - 55f)) return 12
    // Select: cx = 70f, cy = hDp - 35f
    if (x < 120f && y > hDp - 55f) return 2
    
    // Start: cx = wDp - 70f, cy = hDp - 40f
    if (x > wDp - 120f && y > hDp - 70f) return 3
    
    return -1
}

private fun getPortraitButtonAt(x: Float, y: Float, wDp: Float, hDp: Float): Int {
    // D-PAD: cx = 90f, cy = hDp / 2f - 3f
    val dpadCx = 90f
    val dpadCy = hDp / 2f - 3f
    if (dist(x, y, dpadCx, dpadCy) < 80f) {
        val dx = x - dpadCx
        val dy = y - dpadCy
        return if (Math.abs(dx) > Math.abs(dy)) {
            if (dx > 0) 7 else 6
        } else {
            if (dy > 0) 5 else 4
        }
    }
    
    // A: cx = wDp - 50f, cy = hDp / 2f - 30f
    if (dist(x, y, wDp - 50f, hDp / 2f - 30f) < 55f) return 8
    // B: cx = wDp - 120f, cy = hDp / 2f + 20f
    if (dist(x, y, wDp - 120f, hDp / 2f + 20f) < 55f) return 0
    
    // Turbo: cx = 60f, cy = 10f
    if (x < 110f && y < 35f) return 12
    // L: cx = 60f, cy = 75f
    if (x < 110f && y in 35f..105f) return 10
    // R: cx = wDp - 60f, cy = 75f
    if (x > wDp - 110f && y < 105f) return 11
    
    // Select: cx = wDp / 2f - 60f, cy = hDp - 40f
    if (dist(x, y, wDp / 2f - 60f, hDp - 40f) < 50f) return 2
    // Start: cx = wDp / 2f + 60f, cy = hDp - 40f
    if (dist(x, y, wDp / 2f + 60f, hDp - 40f) < 50f) return 3
    
    return -1
}

private fun dist(x1: Float, y1: Float, x2: Float, y2: Float): Float {
    val dx = x1 - x2
    val dy = y1 - y2
    return Math.sqrt((dx * dx + dy * dy).toDouble()).toFloat()
}


